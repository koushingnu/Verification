# このファイルをコピーして .env.local を作成してください（.env.local はGit管理対象外）
# Vercelにデプロイする場合は、同じ変数を Project Settings > Environment Variables に設定してください。

# ── アプリ全体のBasic認証（社内限定アクセス用。必須） ─────────────────
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=admin

# ── さくらサーバー 1 ────────────────────────────────────────────
# HOST が未設定のサーバーは一覧に表示されません。
SAKURA_SERVER_1_LABEL=本番サーバー
SAKURA_SERVER_1_HOST=ttsv.sakura.ne.jp
SAKURA_SERVER_1_PORT=21
SAKURA_SERVER_1_USER=ttsv
SAKURA_SERVER_1_PASSWORD=zDzsSYfZNJkm3Fys
# 検索・閲覧を許可するルートディレクトリ（この配下しかアクセスできません）
SAKURA_SERVER_1_BASE_DIR=/home/ttsv/www/maruyama/form/upload_id
# FTPS(明示的TLS)を使う場合はtrue（推奨）。プレーンFTPしか使えない環境ではfalse。
SAKURA_SERVER_1_SECURE=false

# ── さくらサーバー 2 ────────────────────────────────────────────
SAKURA_SERVER_2_LABEL=検証サーバー
SAKURA_SERVER_2_HOST=
SAKURA_SERVER_2_PORT=21
SAKURA_SERVER_2_USER=
SAKURA_SERVER_2_PASSWORD=
SAKURA_SERVER_2_BASE_DIR=
SAKURA_SERVER_2_SECURE=true

# ── さくらサーバー 3 ────────────────────────────────────────────
SAKURA_SERVER_3_LABEL=
SAKURA_SERVER_3_HOST=
SAKURA_SERVER_3_PORT=21
SAKURA_SERVER_3_USER=
SAKURA_SERVER_3_PASSWORD=
SAKURA_SERVER_3_BASE_DIR=
SAKURA_SERVER_3_SECURE=true

# ── 検索の上限（任意。未設定時は下記デフォルト値を使用） ───────────────
# SEARCH_MAX_DEPTH=6
# SEARCH_MAX_RESULTS=100
# SEARCH_MAX_SCANNED=5000
